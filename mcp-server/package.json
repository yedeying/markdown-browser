{
  "name": "vmd-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for vmd shared file/folder API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "bun dist/index.js",
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  }
}
